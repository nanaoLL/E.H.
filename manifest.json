{
  "manifest_version": 3,
  "name": "레츠도로 알리미",
  "version": "1.0",
  "description": "신규 티켓 등록 및 풀방 시 알림 기능 제공 (서버 필터링, 주차 목표 설정 가능) / 티켓 알림 클릭 시 협전 코드 자동 복사",
  "permissions": [
    "notifications",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://letsdoro.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://letsdoro.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}